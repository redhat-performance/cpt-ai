# CPT AI Configuration
# Copy this file to .env and fill in your values.

# --- MCP Server ---
MCP_URL=http://localhost:9900/sse
OPENSEARCH_CLUSTER=zathras
OPENSEARCH_INDEX=zathras-results

# --- OpenSearch (for show_data_tree.py direct access) ---
OPENSEARCH_HOST=your-opensearch-host.example.com
OPENSEARCH_PORT=443
OPENSEARCH_USERNAME=your-username
OPENSEARCH_PASSWORD=your-password

# --- AI Model (uncomment one block) ---

# Option 1: Red Hat models.corp Granite
#MODEL_NAME=granite-3-3-8b-instruct
#MODELS_CORP_API_KEY=your-api-key
#MODELS_CORP_ENDPOINT=https://your-granite-endpoint/v1

# Option 2: Google Gemini
#MODEL_NAME=gemini-2.0-flash
#MODELS_CORP_API_KEY=your-gemini-api-key
#MODELS_CORP_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/openai

# --- SSL ---
SSL_VERIFY=false
